# ─────────────────────────────────────────────────────────────────────────────
# ScopeSnap API — Environment Variables
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to git (it is in .gitignore).
#
# LOCAL DEV:   ENVIRONMENT=development  → LocalStorage + ConsoleSender ($0)
# PRODUCTION:  ENVIRONMENT=production   → R2Storage + ResendSender (cloud)
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Set to "production" on Railway for cloud storage + real email sending

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: postgres running locally (or docker-compose)
DATABASE_URL=postgresql+asyncpg://postgres:devpass@localhost:5432/scopesnap_dev
# Production (Railway): paste the Railway PostgreSQL connection string
# DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@HOST:PORT/railway

# ── File Upload Directory (local dev only) ────────────────────────────────────
# In production, files are stored on Cloudflare R2 (ENVIRONMENT=production)
UPLOAD_DIR=./uploads

# ── Gemini Vision AI ──────────────────────────────────────────────────────────
# Get free key at: https://aistudio.google.com/app/apikey
# Free tier: 1,500 req/day — enough for ~500 assessments/day
GEMINI_API_KEY=

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → Your App → API Keys
#
# IMPORTANT — Clerk has TWO key sets: Development and Production.
#   Local dev:   use Development keys  (sk_test_... / pk_test_...)
#   Railway:     use Production keys   (sk_live_... / pk_live_...)
#   Switch in Clerk Dashboard: top-left environment toggle → "Production"
#   Production keys require a custom domain configured in Clerk.
#
CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Webhook secret — Clerk Dashboard → Webhooks → Add endpoint → signing secret
# Endpoint URL: https://your-railway-app.up.railway.app/api/webhooks/clerk
CLERK_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API Keys
# Test keys: sk_test_... (no real charges)  Live keys: sk_live_...
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Webhook secret — Stripe Dashboard → Webhooks → endpoint → signing secret
# Events to enable: checkout.session.completed, payment_intent.succeeded
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get free key at: https://resend.com → API Keys
# Free tier: 3,000 emails/month. No credit card needed.
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FROM_EMAIL=estimates@scopesnap.ai

# ── Cloudflare R2 (Production File Storage) ───────────────────────────────────
# Get from: Cloudflare Dashboard → R2 → your bucket → Manage R2 API tokens
# Free tier: 10 GB storage, 1M Class-A ops/month — zero egress fees
# Not needed for local dev (ENVIRONMENT=development uses ./uploads/ folder).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=scopesnap-photos
# Public URL — use custom domain or the r2.dev subdomain
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.r2.dev

# ── URLs ──────────────────────────────────────────────────────────────────────
# Local dev — leave as-is
FRONTEND_URL=http://localhost:3000
REPORT_BASE_URL=http://localhost:3000/r
# Production (Railway) — set these to the actual deployed domains
# FRONTEND_URL=https://scope-snap-ai.vercel.app
# REPORT_BASE_URL=https://scope-snap-ai.vercel.app/r

# ── Admin Endpoints (optional, production only) ────────────────────────────────
# Protects POST /admin/seed and GET /admin/status endpoints.
# Generate with: openssl rand -hex 32
# If not set, admin endpoints return 503 (disabled).
ADMIN_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# RAILWAY PRODUCTION ENVIRONMENT VARIABLES (set in Railway dashboard)
# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT=production
# DATABASE_URL=${{Postgres.DATABASE_URL}}   ← auto-injected by Railway
# GEMINI_API_KEY=<your-key>
# CLERK_SECRET_KEY=<sk_live_...>            ← use Production keys in Railway
# RESEND_API_KEY=<re_...>
# FROM_EMAIL=estimates@scopesnap.ai         ← must be verified in Resend
# R2_ACCOUNT_ID=<cloudflare-account-id>
# R2_ACCESS_KEY_ID=<r2-token-key-id>
# R2_SECRET_ACCESS_KEY=<r2-token-secret>
# R2_BUCKET_NAME=scopesnap-photos
# R2_PUBLIC_URL=https://pub-xxx.r2.dev
# FRONTEND_URL=https://scope-snap-ai.vercel.app
# REPORT_BASE_URL=https://scope-snap-ai.vercel.app/r
# ADMIN_SECRET=<openssl rand -hex 32>
#
# DATABASE SEEDS — run automatically on startup (no manual action needed).
# Pricing rules and equipment models are seeded if tables are empty.
# Re-seed manually: POST /admin/seed with X-Admin-Secret header.
# ─────────────────────────────────────────────────────────────────────────────
