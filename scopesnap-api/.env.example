# ── ScopeSnap API — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (SQLite): sqlite:////tmp/scopesnap_dev.db
# Docker Compose: postgresql+asyncpg://postgres:devpass@db:5432/scopesnap_dev
# Cloud (Supabase, Neon, Railway): your connection string here
DATABASE_URL=postgresql+asyncpg://postgres:devpass@db:5432/scopesnap_dev

# ── Environment ───────────────────────────────────────────────────────────────
# "development" → LocalStorage + ConsoleSender + MockPayment (zero external calls)
# "production"  → R2Storage + ResendSender + StripePayment
ENVIRONMENT=production

# ── File Upload Directory (local dev only) ────────────────────────────────────
# In production, files are stored on Cloudflare R2 (set ENVIRONMENT=production)
UPLOAD_DIR=/app/uploads

# ── Gemini Vision AI ──────────────────────────────────────────────────────────
# Get free key at: https://aistudio.google.com
# Free tier: 1,500 req/day — enough for ~500 assessments/day
GEMINI_API_KEY=

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
# Get from: Clerk Dashboard → Webhooks → Add endpoint → /api/webhooks/clerk
CLERK_WEBHOOK_SECRET=whsec_...

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
# Get from: Stripe Dashboard → Developers → Webhooks → Add endpoint → /api/webhooks/stripe
# Events to enable: checkout.session.completed, payment_intent.succeeded
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get free key at: https://resend.com → API Keys
# Free tier: 100 emails/day, 3,000/month
RESEND_API_KEY=re_...
FROM_EMAIL=estimates@yourdomain.com

# ── Cloudflare R2 (Production File Storage) ───────────────────────────────────
# Get from: Cloudflare Dashboard → R2 → API Tokens
# Free tier: 10GB storage, 1M operations/month
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=scopesnap-photos
R2_PUBLIC_URL=https://photos.yourdomain.com

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://app.yourdomain.com
REPORT_BASE_URL=https://app.yourdomain.com/r
