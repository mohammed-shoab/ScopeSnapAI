# ============================================================
# ScopeSnap Web — Environment Variables (Next.js)
# Copy this file to .env.local and fill in your values
# ============================================================

# API URL — FastAPI backend
# Local dev: http://localhost:8000
# Production: https://your-api.run.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# Clerk Auth — Get free keys from clerk.com
# Dev keys: Start at clerk.com, create app, copy keys (no credit card needed)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Report Base URL — used for homeowner report links
# Local dev: http://localhost:3000/r
NEXT_PUBLIC_REPORT_BASE_URL=http://localhost:3000/r
