# ── ScopeSnap Web — Environment Variables ─────────────────────────────────────
# Copy this file to .env.local (dev) or .env.production (prod)
# NEVER commit files with real keys to git.

# ── API Connection ────────────────────────────────────────────────────────────
# Where the FastAPI backend is running
NEXT_PUBLIC_API_URL=http://localhost:8001
# Internal API URL for SSR (server-side) calls — use Docker service name in Docker
API_URL=http://localhost:8001

# ── Clerk Authentication ──────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# ── Environment ───────────────────────────────────────────────────────────────
# "development" → skip Clerk auth, use dev bypass headers
# "production"  → enforce Clerk JWT auth on all routes
NEXT_PUBLIC_ENV=production
NODE_ENV=production

# ── PWA / Build ───────────────────────────────────────────────────────────────
# Set to "true" to enable standalone Docker build output
NEXT_STANDALONE=true
NEXT_TELEMETRY_DISABLED=1
