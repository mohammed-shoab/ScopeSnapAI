# ─────────────────────────────────────────────────────────────────────────────
# SnapAI Web — Environment Variables
# Copy this file to .env.local for local dev or set in Vercel dashboard.
# NEVER commit files with real keys to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── API Connection ────────────────────────────────────────────────────────────
# Local dev: FastAPI running on port 8000
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production: your Railway API service URL
# NEXT_PUBLIC_API_URL=https://scopesnap-api.up.railway.app

# ── Clerk Authentication ──────────────────────────────────────────────────────
# Get from: https://dashboard.clerk.com → Your App → API Keys
#
# IMPORTANT — Clerk has TWO key sets: Development and Production.
#   Local dev:   use Development keys  (pk_test_... / sk_test_...)
#   Vercel:      use Production keys   (pk_live_... / sk_live_...)
#   Switch in Clerk Dashboard: top-left environment toggle → "Production"
#   Production keys require a custom domain added in Clerk → Domains.
#
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Feature Flags (beta — hide non-essential pages) ──────────────────────────
# Set to "false" to hide a page/section during beta.
# All default to "true" (shown). Flip to "false" to suppress.
NEXT_PUBLIC_SHOW_ANALYTICS=false
NEXT_PUBLIC_SHOW_PROFIT_LEAKS=false
NEXT_PUBLIC_SHOW_JOBS=false
NEXT_PUBLIC_SHOW_INTEL=false

# ── Environment ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENV=development
NODE_ENV=development
# Production values:
# NEXT_PUBLIC_ENV=production
# NODE_ENV=production

# ── Build ─────────────────────────────────────────────────────────────────────
NEXT_TELEMETRY_DISABLED=1
